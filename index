<!DOCTYPE html>

<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fusion Surprise</title>

<style>

body{
margin:0;
font-family:Arial;
background:radial-gradient(circle,#0f0f1a,#000);
color:white;
text-align:center;
overflow:hidden;
}

h1{
margin-top:30px;
}

.container{
display:flex;
justify-content:center;
align-items:center;
gap:30px;
margin-top:80px;
flex-wrap:wrap;
}

img{
width:160px;
border-radius:20px;
box-shadow:0 0 20px #fff3;
transition:1s;
}

button{
margin-top:40px;
padding:15px 40px;
font-size:20px;
border:none;
border-radius:30px;
background:#ff0088;
color:white;
cursor:pointer;
box-shadow:0 0 20px #ff0088;
}

button:hover{
transform:scale(1.1);
}

#result{
display:none;
margin-top:30px;
}

#result img{
width:260px;
animation:pop 1s;
}

@keyframes pop{
from{transform:scale(0);}
to{transform:scale(1);}
}

.lightning{
position:absolute;
width:5px;
height:200px;
background:white;
top:50%;
left:50%;
transform:translate(-50%,-50%);
opacity:0;
box-shadow:0 0 20px white,0 0 40px cyan;
}

.explosion{
position:absolute;
width:200px;
height:200px;
border-radius:50%;
background:radial-gradient(circle,yellow,orange,red);
top:50%;
left:50%;
transform:translate(-50%,-50%) scale(0);
opacity:0;
}

.confetti{
position:absolute;
width:8px;
height:8px;
background:red;
top:-10px;
animation:fall 3s linear infinite;
}

@keyframes fall{
to{
transform:translateY(110vh) rotate(360deg);
}
}

@media(max-width:600px){

img{
width:120px;
}

#result img{
width:200px;
}

}

</style>

</head>

<body>

<h1>⚡ Fusion Combine ⚡</h1>

<div class="container">

<img id="p1" src="person1.jpg">
<h2>+</h2>
<img id="p2" src="person2.jpg">

</div>

<button onclick="fusion()">รวมร่าง!</button>

<div id="result">
<h2>🔥 ผลลัพธ์ 🔥</h2>
<img src="fusion.jpg">
</div>

<div class="lightning" id="lightning"></div>
<div class="explosion" id="boom"></div>

<audio id="sound">
<source src="https://www.myinstants.com/media/sounds/anime-wow-sound-effect.mp3">
</audio>

<script>

function fusion(){

let p1=document.getElementById("p1")
let p2=document.getElementById("p2")
let lightning=document.getElementById("lightning")
let boom=document.getElementById("boom")
let sound=document.getElementById("sound")

sound.play()

p1.style.transform="translateX(120px) rotate(360deg)"
p2.style.transform="translateX(-120px) rotate(-360deg)"

setTimeout(()=>{

lightning.style.opacity=1

},500)

setTimeout(()=>{

lightning.style.opacity=0
boom.style.opacity=1
boom.style.transform="translate(-50%,-50%) scale(3)"

},800)

setTimeout(()=>{

p1.style.display="none"
p2.style.display="none"
document.getElementById("result").style.display="block"

confetti()

},1200)

}

function confetti(){

for(let i=0;i<80;i++){

let c=document.createElement("div")

c.className="confetti"
c.style.left=Math.random()*100+"vw"
c.style.background="hsl("+Math.random()*360+",100%,50%)"
c.style.animationDuration=(2+Math.random()*3)+"s"

document.body.appendChild(c)

}

}

</script>

</body>
</html>
